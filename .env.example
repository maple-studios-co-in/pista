# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Database — local SQLite by default. For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/shoku"
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Multi-tenant
BASE_DOMAIN="shoku.maplestudios.co.in"
NEXT_PUBLIC_BASE_DOMAIN="shoku.maplestudios.co.in"
DEFAULT_TENANT_SLUG="cbtl"
# Set this ONLY in production once café subdomains are live, to share the login
# session across *.shoku… subdomains. Leave unset for local/single-host.
# COOKIE_DOMAIN=".shoku.maplestudios.co.in"

# Payments (Razorpay). Leave unset to keep the mock checkout (orders are created
# as paid without a real charge). Set all three to enable real payments:
#   1. Keys from the Razorpay Dashboard → Settings → API Keys
#   2. Webhook secret from Dashboard → Webhooks (point it at
#      https://<your-host>/api/payments/razorpay/webhook, events: payment.captured, payment.failed)
# RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
# RAZORPAY_KEY_SECRET="your-razorpay-key-secret"
# RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
