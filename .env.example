# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Database — local SQLite by default. For production use Postgres:
#   DATABASE_URL="postgresql://user:pass@host:5432/pista"
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Multi-tenant
BASE_DOMAIN="pista.maplestudios.co.in"
NEXT_PUBLIC_BASE_DOMAIN="pista.maplestudios.co.in"
DEFAULT_TENANT_SLUG="cbtl"
# Set this ONLY in production once café subdomains are live, to share the login
# session across *.pista… subdomains. Leave unset for local/single-host.
# COOKIE_DOMAIN=".pista.maplestudios.co.in"
