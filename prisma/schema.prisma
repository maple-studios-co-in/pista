generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A café / tenant on the Shoku platform. Holds its white-label config.
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // subdomain label, e.g. "cbtl"
  status      String   @default("active") // active | trial | suspended
  plan        String   @default("growth") // starter | growth | enterprise
  // white-label
  brandHex    String   @default("#3A6B4D")
  darkHex     String   @default("#244635")
  font        String   @default("Inter")
  // ai feature flags
  aiAssistant Boolean  @default(true)
  aiCards     Boolean  @default(true)
  aiUpsell    Boolean  @default(true)
  aiLoyalty   Boolean  @default(false)
  // store info
  storeName   String?
  address     String?
  // loyalty
  loyaltyEarnRate Int    @default(10)   // points earned per ₹100 spent
  tiers           String @default("[]") // JSON: [{name,min}]
  // WhatsApp marketing (provider-agnostic; empty creds => demo/log mode)
  waProvider  String?  // meta | twilio | bsp | null(demo)
  waEnabled   Boolean  @default(false)
  waFromName  String?
  waConfig    String   @default("{}") // JSON creds per provider
  waTriggers  Boolean  @default(true)  // auto order-confirmation / ready
  waNudges    Boolean  @default(true)  // reward-close / win-back nudges
  // POS add-on (billing + KOT + GST invoices + day-end)
  posEnabled    Boolean @default(false)
  gstin         String?               // 15-char GSTIN printed on invoices
  gstRate       Int     @default(5)   // % — restaurant-service norm
  invoicePrefix String  @default("INV")
  invoiceSeq    Int     @default(0)   // last issued number (atomic increment)
  kotAutoPrint  Boolean @default(true)
  createdAt   DateTime @default(now())

  categories Category[]
  items      Item[]
  orders     Order[]
  discounts  Discount[]
  users      User[]
  rewards    Reward[]
  feedback   Feedback[]
  tables     Table[]
  banners    Banner[]
  campaigns  Campaign[]
  messages   Message[]
}

model Table {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  label     String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  orders    Order[]

  @@index([tenantId])
}

model Feedback {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  userId    String?
  orderId   String?
  name      String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Reward {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  title     String
  type      String   @default("discount") // discount | freeItem
  cost      Int      // points required to redeem
  amount    Int      @default(0)          // ₹ off (discount type)
  itemId    String?                        // free item (freeItem type)
  itemName  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Category {
  id       String  @id // composite-ish: "<tenant>:<slug>" to stay unique across tenants
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  key      String  @default("") // logical id within a tenant, e.g. "ice-blended"
  label    String
  sort     Int     @default(0)
  items    Item[]

  @@index([tenantId])
}

model Item {
  id          String      @id
  tenantId    String?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  name        String
  price       Int
  img         String
  desc        String
  veg         Boolean     @default(true)
  kcal        Int         @default(0)
  caffeine    Int         @default(0)
  protein     Int         @default(0)
  sugar       Int         @default(0)
  signature   Boolean     @default(false)
  rating      Float       @default(0)
  reviews     Int         @default(0)
  origin      String      @default("")
  ingredients String      @default("[]")
  allergens   String      @default("[]")
  tags        String      @default("[]")
  sizes       String      @default("[]")
  aiTip       String      @default("")
  live        Boolean     @default(true)
  sort        Int         @default(0)
  orderItems  OrderItem[]

  @@index([tenantId])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String? // null for platform superadmins
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  name      String?
  email     String
  password  String
  role      String   @default("customer") // superadmin | owner | staff | customer
  points    Int      @default(120)
  phone     String?
  waOptIn   Boolean  @default(true) // WhatsApp marketing consent
  inviteToken   String?   @unique
  inviteExpires DateTime?
  createdAt DateTime @default(now())
  orders    Order[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Order {
  id           String      @id @default(cuid())
  tenantId     String?
  tenant       Tenant?     @relation(fields: [tenantId], references: [id])
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  subtotal     Int
  tax          Int
  reward       Int
  discount     Int         @default(0)
  discountCode String?
  loyaltyDiscount Int      @default(0)
  pointsRedeemed  Int      @default(0)
  rewardTitle     String?
  total        Int
  fulfilment   String      @default("pickup")
  payment      String      @default("upi")
  paymentStatus     String  @default("paid")   // paid | pending | failed
  razorpayOrderId   String?
  razorpayPaymentId String?
  // POS (source="pos") fields
  source        String  @default("online") // online | pos
  paymentMethod String?                    // cash | upi | card
  invoiceNo     String?                    // e.g. "INV-2026-00042"
  cgst          Int     @default(0)        // GST display split (cgst+sgst = tax)
  sgst          Int     @default(0)
  staffId       String?                    // user who billed it
  tableId      String?
  tableLabel   String?
  table        Table?      @relation(fields: [tableId], references: [id])
  status       String      @default("preparing")
  createdAt    DateTime    @default(now())
  items        OrderItem[]

  @@index([tenantId])
  @@index([userId])
  @@index([razorpayOrderId])
}

model OrderItem {
  id      String  @id @default(cuid())
  orderId String
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item    @relation(fields: [itemId], references: [id])
  name    String
  size    String  @default("Regular")
  milk    String?
  unit    Int
  qty     Int
}

model Discount {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  code      String
  percent   Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([tenantId, code])
  @@index([tenantId])
}


model Banner {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  title     String?
  subtitle  String?
  imageUrl  String
  link      String?
  active    Boolean  @default(true)
  sort      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Campaign {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  segment   String   @default("all") // segment key
  template  String   @default("")    // base copy the AI personalizes
  status    String   @default("draft") // draft | sent
  audience  Int      @default(0)
  sentCount Int      @default(0)
  createdAt DateTime @default(now())
  messages  Message[]

  @@index([tenantId])
}

model Message {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  userId     String?
  channel    String   @default("whatsapp")
  kind       String   @default("campaign") // campaign | trigger | nudge
  toName     String?
  to         String   // phone
  body       String
  status     String   @default("demo") // demo | queued | sent | failed
  provider   String?
  error      String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([campaignId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorRole  String?
  action     String
  target     String?
  meta       String?  // JSON
  createdAt  DateTime @default(now())

  @@index([createdAt])
}


model PitchDeck {
  id         String   @id @default(cuid())
  kind       String   @default("pdf") // pdf | pptx
  version    Int      @default(1)
  filename   String
  mime       String   @default("application/pdf")
  size       Int      @default(0)
  data       Bytes
  uploadedBy String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
